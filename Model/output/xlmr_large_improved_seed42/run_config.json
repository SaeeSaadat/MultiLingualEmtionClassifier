{
  "_comment": "Improved recipe: focal loss + rare-class reweighting + translation augmentation. Per-language thresholds applied afterwards via apply_per_lang_thresholds.py. ~30 min/run.",
  "seed": 42,
  "output_dir": "outputs/xlmr_large_improved_seed42",
  "train_langs": [
    "eng",
    "deu",
    "arq"
  ],
  "model_name": "xlm-roberta-large",
  "mode": "per_lang",
  "dropout": 0.1,
  "freeze_encoder_layers": 0,
  "lang_balanced_sampling": true,
  "epochs": 15,
  "batch_size": 32,
  "gradient_accumulation_steps": 2,
  "learning_rate": 1e-05,
  "weight_decay": 0.01,
  "warmup_ratio": 0.1,
  "max_length": 160,
  "fp16": false,
  "bf16": true,
  "patience": 4,
  "internal_dev_ratio": 0.15,
  "calib_ratio": 0.4,
  "use_augmented": true,
  "loss_type": "focal",
  "focal_gamma": 2.0,
  "pos_weight_cap": 20.0,
  "num_workers": 6,
  "grad_clip": 1.0,
  "num_labels": 7
}